# Cloudflare Pages — security headers
# HSTS senza includeSubDomains/preload per non interferire con i sottodomini
# della posta (mail/pop/autoconfig) gestiti da Register.

/*
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com https://api.web3forms.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com; upgrade-insecure-requests

# Il pannello CMS carica l'app da CDN e chiama API esterne: CSP rilassata qui.
/admin/*
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; img-src 'self' https: data: blob:; connect-src 'self' https: wss:; frame-ancestors 'self'

# Cache lunga per gli asset con hash nel nome
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
