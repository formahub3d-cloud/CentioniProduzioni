---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'works'>;
  /** Eager-load the first cards above the fold. */
  eager?: boolean;
  /** Stagger index for the reveal cascade. */
  index?: number;
}

const { work, eager = false, index = 0 } = Astro.props;
const { title, cover, video, role, year } = work.data;
const meta = [role, year].filter(Boolean).join(' · ');
---

<a
  href={video}
  class="work reveal"
  style={`--i: ${index}`}
  target="_blank"
  rel="noopener"
  aria-label={`${title} — guarda il video (si apre in una nuova scheda)`}
>
  <figure class="work__media wipe">
    <Image
      src={cover}
      alt={`Copertina del lavoro ${title}`}
      widths={[480, 800, 1200]}
      sizes="(min-width: 60rem) 50vw, 100vw"
      loading={eager ? 'eager' : 'lazy'}
    />
    <span class="work__play" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </figure>
  <figcaption class="work__caption">
    <h3 class="work__title">{title}</h3>
    {meta && <p class="work__meta">{meta}</p>}
  </figcaption>
</a>

<style>
  .work {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .work__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-line);
    aspect-ratio: 16 / 10;
    margin: 0;
  }

  .work__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease), filter 0.5s var(--ease);
    filter: grayscale(1);
  }

  .work:hover .work__media :global(img),
  .work:focus-visible .work__media :global(img) {
    transform: scale(1.05);
    filter: grayscale(1) contrast(1.06);
  }

  .work__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 3.6rem;
    height: 3.6rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
    backdrop-filter: blur(2px);
    transform: scale(0.85);
    opacity: 0;
    transition: opacity 0.35s var(--ease), transform 0.35s var(--ease);
  }

  .work__play svg {
    transform: translateX(1px);
  }

  .work:hover .work__play,
  .work:focus-visible .work__play {
    opacity: 1;
    transform: scale(1);
  }

  .work__caption {
    margin-top: var(--space-2);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .work__title {
    font-size: var(--step-1);
  }

  .work__meta {
    font-family: var(--font-sans);
    color: var(--color-muted);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .work__play {
      opacity: 1;
      transform: none;
    }
  }
</style>
