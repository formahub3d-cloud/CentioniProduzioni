---
/**
 * Google Analytics 4 — attivo solo se la variabile di build `PUBLIC_GA_ID`
 * (Measurement ID, es. "G-XXXXXXXXXX") è impostata su Cloudflare Pages.
 * Senza variabile il componente non emette nulla: zero JS in più.
 *
 * Lo script è processato da Astro (file esterno), così resta compatibile con
 * la CSP `script-src 'self' https://www.googletagmanager.com` (public/_headers).
 */
const GA_ID = import.meta.env.PUBLIC_GA_ID ?? '';
---

{GA_ID && (
  <script>
    const id = import.meta.env.PUBLIC_GA_ID;
    if (id && import.meta.env.PROD) {
      const s = document.createElement('script');
      s.src = `https://www.googletagmanager.com/gtag/js?id=${id}`;
      s.async = true;
      document.head.appendChild(s);
      // @ts-ignore — API globale di gtag
      window.dataLayer = window.dataLayer || [];
      // @ts-ignore
      function gtag(...args) { window.dataLayer.push(arguments); }
      // @ts-ignore
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', id);
    }
  </script>
)}
