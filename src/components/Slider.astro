---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Slide {
  src: ImageMetadata;
  label?: string;
}
interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
// Tuned for 3–5 highlights; each slide is shown ~one fifth of the loop.
const dur = slides.length * 3.6;
---

<div
  class="slider"
  style={`--n:${slides.length}; --dur:${dur}s`}
  role="group"
  aria-label="Momenti salienti delle produzioni"
>
  {
    slides.map((s, i) => (
      <figure class="slide" style={`--idx:${i}`}>
        <Image
          src={s.src}
          alt={s.label ?? ''}
          widths={[800, 1280, 1800]}
          sizes="100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        {s.label && <figcaption class="slide__cap">{s.label}</figcaption>}
      </figure>
    ))
  }
  <div class="slider__dots" aria-hidden="true">
    {slides.map((_, i) => <span class="slider__dot" style={`--idx:${i}`} />)}
  </div>
</div>

<style>
  .slider {
    position: relative;
    aspect-ratio: 16 / 8;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-ink);
  }
  @media (min-width: 48rem) {
    .slider {
      aspect-ratio: 16 / 6;
    }
  }

  .slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    animation: slidefade var(--dur) infinite;
    animation-delay: calc(var(--idx) * (var(--dur) / var(--n)) * -1);
  }
  .slide :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .slide__cap {
    position: absolute;
    left: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 1.8rem);
    color: #fff;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 3.5vw, 2.2rem);
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.4);
  }

  /* visible window ≈ 100/n %, with short crossfades */
  @keyframes slidefade {
    0% {
      opacity: 0;
    }
    2% {
      opacity: 1;
    }
    21% {
      opacity: 1;
    }
    25% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .slider__dots {
    position: absolute;
    bottom: clamp(0.8rem, 2vw, 1.4rem);
    right: clamp(1rem, 3vw, 2rem);
    display: flex;
    gap: 0.5rem;
  }
  .slider__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    animation: dotpulse var(--dur) infinite;
    animation-delay: calc(var(--idx) * (var(--dur) / var(--n)) * -1);
  }
  @keyframes dotpulse {
    0%,
    22%,
    100% {
      background: rgba(255, 255, 255, 0.4);
    }
    3%,
    19% {
      background: #fff;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide {
      animation: none;
    }
    .slide:first-of-type {
      opacity: 1;
    }
    .slider__dot {
      animation: none;
    }
  }
</style>
