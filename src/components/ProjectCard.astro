---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Eager-load the first few cards above the fold. */
  eager?: boolean;
}

const { project, eager = false } = Astro.props;
const { title, cover, year, role } = project.data;
---

<a
  href={`/portfolio/${project.id}`}
  class="card reveal"
  style={`view-transition-name: project-${project.id}`}
>
  <div class="card__media">
    <Image
      src={cover}
      alt={`Copertina del progetto ${title}`}
      widths={[400, 700, 1000]}
      sizes="(min-width: 56rem) 33vw, (min-width: 36rem) 50vw, 100vw"
      loading={eager ? 'eager' : 'lazy'}
    />
  </div>
  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__meta">{role} · {year}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card__media {
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-line);
    aspect-ratio: 4 / 3;
  }

  .card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .card:hover .card__media :global(img) {
    transform: scale(1.04);
  }

  .card__body {
    margin-top: var(--space-2);
  }

  .card__title {
    font-size: var(--step-1);
  }

  .card__meta {
    color: var(--color-muted);
    font-size: var(--step--1);
    margin-top: 0.15rem;
  }
</style>
