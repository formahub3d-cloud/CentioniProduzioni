---
import { SITE, SOCIAL } from '../data/site.ts';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or root-relative URL of the social share image. */
  image?: string;
  /** 'website' | 'article' */
  type?: 'website' | 'article';
  /** Set true on pages that should not be indexed (e.g. drafts). */
  noindex?: boolean;
  /** One JSON-LD object or an array of them (page-specific). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE.description,
  image,
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image ?? SITE.ogImage, SITE.url).href;

// Sitewide entity graph (Organization + WebSite) — good for SEO/GEO.
const sameAs = SOCIAL.filter((s) => /^https?:\/\//.test(s.href)).map((s) => s.href);
const siteGraph: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: new URL('/logo-mark.svg', SITE.url).href,
    email: SITE.email,
    ...(sameAs.length ? { sameAs } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    inLanguage: 'it-IT',
  },
];

const pageGraph = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...siteGraph, ...pageGraph];
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{
  allJsonLd.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))
}
