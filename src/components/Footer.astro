---
import { SOCIAL, SITE, NAV } from '../data/site.ts';
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap site-footer__inner">
    <div>
      <p class="site-footer__brand">
        <span class="site-footer__mark"><Logo size={28} /></span>
        {SITE.name}
      </p>
      <p class="site-footer__tag">{SITE.description}</p>
      <p class="site-footer__mail">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
    </div>

    <nav aria-label="Footer">
      <ul class="site-footer__nav">
        {NAV.map((i) => (
          <li><a href={i.href}>{i.label}</a></li>
        ))}
      </ul>
    </nav>

    {
      SOCIAL.length > 0 && (
        <nav aria-label="Social">
          <ul class="site-footer__nav">
            {SOCIAL.map((i) => (
              <li>
                <a href={i.href} rel="me noopener" target="_blank">
                  {i.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>

  <div class="wrap site-footer__copy">
    <span>© {year} {SITE.name}</span>
    <a href="/privacy">Privacy</a>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-6);
    border-top: 1px solid var(--color-line);
    padding-block: var(--space-4) var(--space-3);
    background: var(--color-surface);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: space-between;
  }

  .site-footer__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: var(--step-1);
  }
  .site-footer__mark {
    color: var(--color-accent);
    display: inline-flex;
  }
  .site-footer__mail {
    margin-top: 0.4rem;
    font-size: var(--step--1);
  }
  .site-footer__mail a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-footer__tag {
    color: var(--color-muted);
    font-size: var(--step--1);
    max-width: var(--measure);
    margin-top: 0.25rem;
  }

  .site-footer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: var(--step--1);
  }

  .site-footer__nav a {
    text-decoration: none;
    color: var(--color-ink-soft);
  }

  .site-footer__nav a:hover {
    color: var(--color-accent);
  }

  .site-footer__copy {
    margin-top: var(--space-4);
    font-size: var(--step--1);
    color: var(--color-muted);
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .site-footer__copy a {
    color: var(--color-muted);
    text-decoration: none;
  }
  .site-footer__copy a:hover {
    color: var(--color-accent);
  }
</style>
