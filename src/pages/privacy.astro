---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.ts';

const updated = '2 luglio 2026';
const hasGA = Boolean(import.meta.env.PUBLIC_GA_ID);
---

<BaseLayout
  title="Privacy"
  description="Informativa privacy di Centioni Produzioni: dati del form di contatto e analytics."
>
  <section class="wrap page-head">
    <p class="eyebrow reveal">Privacy</p>
    <h1 class="reveal reveal-lines"><span class="line"><span>Informativa privacy</span></span></h1>
    <p class="page-head__lead reveal" style="--i:1">Ultimo aggiornamento: {updated}</p>
  </section>

  <section class="wrap prose flow legal">
    <h2>Titolare</h2>
    <p>
      Il titolare del trattamento è <strong>{SITE.name}</strong>. Per qualsiasi
      richiesta relativa ai tuoi dati puoi scrivere a
      <!--email_off--><a href={`mailto:${SITE.email}`}>{SITE.email}</a><!--/email_off-->.
    </p>

    <h2>Modulo di contatto</h2>
    <p>
      Quando usi il modulo nella pagina <a href="/contatti">Contatti</a>,
      raccogliamo i dati che inserisci — <em>nome, email, oggetto e
      messaggio</em> — al solo scopo di leggere e rispondere alla tua richiesta.
      L'invio è gestito dal servizio <strong>Web3Forms</strong>, che inoltra il
      messaggio alla nostra casella email. La base giuridica è il riscontro alla
      tua richiesta; i dati non vengono usati per marketing né ceduti a terzi, e
      vengono conservati per il tempo necessario a gestire il contatto.
    </p>

    <h2>Statistiche di traffico</h2>
    {hasGA ? (
      <p>
        Utilizziamo <strong>Google Analytics 4</strong> per capire, in forma
        statistica, come viene usato il sito. Lo strumento si attiva
        <strong>solo dopo il tuo consenso</strong>, espresso tramite il banner:
        prima della tua scelta nessun dato viene inviato a Google e nessun
        cookie di misurazione viene installato. Le funzioni pubblicitarie sono
        disattivate. Se rifiuti, il sito funziona esattamente allo stesso modo.
      </p>
    ) : (
      <p>
        Il sito non utilizza al momento strumenti di analisi del traffico che
        richiedano consenso.
      </p>
    )}

    <h2>Cookie</h2>
    <p>
      Questo sito <strong>non utilizza cookie di profilazione</strong>.
      {hasGA && (
        <>
          I soli cookie tecnici di misurazione (Google Analytics) vengono
          installati dopo il tuo consenso. La tua scelta è memorizzata nel
          browser e puoi cambiarla quando vuoi:
        </>
      )}
    </p>
    {hasGA && (
      <p>
        <button type="button" class="btn btn--ghost" id="consent-manage">
          Gestisci preferenze cookie
        </button>
      </p>
    )}

    <h2>Hosting e contenuti esterni</h2>
    <p>
      Il sito è ospitato su <strong>Cloudflare Pages</strong>. Alcune pagine
      possono incorporare video di <strong>YouTube</strong>: il player viene
      caricato solo dopo un tuo clic ("click-to-load"), così nessun dato viene
      inviato a YouTube finché non decidi di guardare il video. In quel momento
      si applica l'informativa privacy di YouTube/Google.
    </p>

    <h2>I tuoi diritti</h2>
    <p>
      Puoi richiedere in qualsiasi momento l'accesso, la rettifica o la
      cancellazione dei tuoi dati scrivendo a
      <!--email_off--><a href={`mailto:${SITE.email}`}>{SITE.email}</a><!--/email_off-->.
    </p>
  </section>
</BaseLayout>

<script>
  // "Gestisci preferenze cookie": azzera la scelta e ricarica la pagina,
  // così il banner di consenso riappare.
  function initManage() {
    const btn = document.querySelector<HTMLButtonElement>('#consent-manage');
    if (!btn || btn.dataset.ready) return;
    btn.dataset.ready = 'true';
    btn.addEventListener('click', () => {
      try {
        localStorage.removeItem('cp-consent');
      } catch {}
      location.reload();
    });
  }
  initManage();
  document.addEventListener('astro:page-load', initManage);
</script>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--space-2);
  }
  .page-head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-1);
  }
  .page-head__lead {
    margin-top: var(--space-1);
    color: var(--color-muted);
    font-size: var(--step--1);
  }
  .legal {
    padding-bottom: var(--space-6);
  }
</style>
