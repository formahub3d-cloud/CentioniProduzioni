---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { slugify } from '../../lib/slug.ts';

const posts = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Tag unici (per i chip di filtro)
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'it'),
);
---

<BaseLayout
  title="News"
  description="News e aggiornamenti: novità sui progetti e dal mondo dello spettacolo."
  image="/og/news.jpg"
>
  <section class="wrap page-head">
    <p class="eyebrow reveal">News</p>
    <h1 class="reveal reveal-lines">
      <span class="line"><span>News &amp; Aggiornamenti</span></span>
    </h1>
    <p class="page-head__lead reveal" style="--i: 1">
      Notizie, novità dal mondo dello spettacolo e aggiornamenti sui progetti.
    </p>
    {
      tags.length > 0 && (
        <ul class="tagbar reveal" style="--i: 2" aria-label="Filtra per tag">
          {tags.map((t) => (
            <li>
              <a href={`/news/tag/${slugify(t)}`} class="tagbar__chip">#{t}</a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="wrap">
    {
      posts.length > 0 ? (
        <div class="stack">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p>Nessuna news pubblicata per ora.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--space-4);
  }
  .page-head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-1);
  }
  .page-head__lead {
    margin-top: var(--space-2);
    color: var(--color-ink-soft);
    max-width: var(--measure);
    font-size: var(--step-1);
  }
  .stack {
    display: grid;
    gap: var(--space-5);
  }
  .tagbar {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .tagbar__chip {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-ink-soft);
    padding: 0.35em 0.8em;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .tagbar__chip:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-surface);
  }
</style>
