---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE } from '../../data/site.ts';

export const getStaticPaths = (async () => {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { title, date, cover, excerpt, tags } = post.data;
const { Content } = await render(post);

const ogImage = cover?.src;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  author: { '@type': 'Organization', name: SITE.author },
  publisher: { '@type': 'Organization', name: SITE.name },
  keywords: tags.join(', '),
  url: new URL(`/news/${post.id}`, SITE.url).href,
  ...(ogImage ? { image: new URL(ogImage, SITE.url).href } : {}),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'News', item: new URL('/news', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout
  title={title}
  description={excerpt}
  image={ogImage}
  type="article"
  jsonLd={[jsonLd, breadcrumb]}
>
  <article class="post">
    <header class="wrap post__head">
      <div class="post__meta reveal">
        <FormattedDate date={date} />
        {tags.length > 0 && (
          <ul class="post__tags">
            {tags.map((t) => <li>#{t}</li>)}
          </ul>
        )}
      </div>
      <h1 class="reveal reveal-lines"><span class="line"><span>{title}</span></span></h1>
      <p class="post__excerpt reveal" style="--i: 1">{excerpt}</p>
    </header>

    {
      cover && (
        <div class="wrap post__cover reveal media-reveal">
          <Image
            src={cover}
            alt={`Copertina: ${title}`}
            widths={[600, 1000, 1600]}
            sizes="(min-width: 68rem) 68rem, 100vw"
            loading="eager"
          />
        </div>
      )
    }

    <div class="wrap prose flow">
      <Content />
    </div>

    <div class="wrap post__back">
      <a href="/news" class="link-arrow"><span aria-hidden="true">←</span> Tutte le news</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post__head {
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--space-3);
    max-width: 48rem;
  }
  .post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--step--1);
    color: var(--color-muted);
  }
  .post__tags {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post__head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-2);
  }
  .post__excerpt {
    margin-top: var(--space-2);
    font-size: var(--step-1);
    color: var(--color-ink-soft);
  }
  .post__cover {
    margin-block: var(--space-3) var(--space-5);
  }
  .post__cover :global(img) {
    width: 100%;
    border-radius: var(--radius);
  }
  .post__back {
    margin-top: var(--space-5);
  }
</style>
