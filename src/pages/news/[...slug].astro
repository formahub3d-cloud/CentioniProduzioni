---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE } from '../../data/site.ts';
import { slugify } from '../../lib/slug.ts';

export const getStaticPaths = (async () => {
  const posts = (await getCollection('news', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      older: posts[i + 1]
        ? { id: posts[i + 1].id, title: posts[i + 1].data.title }
        : null,
      newer: posts[i - 1]
        ? { id: posts[i - 1].id, title: posts[i - 1].data.title }
        : null,
    },
  }));
}) satisfies GetStaticPaths;

const { post, older, newer } = Astro.props;
const { title, date, cover, excerpt, tags } = post.data;
const { Content } = await render(post);

// Tempo di lettura stimato dal corpo Markdown (~200 parole/min).
const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));

const ogImage = cover?.src;
const pageUrl = new URL(`/news/${post.id}`, SITE.url).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  inLanguage: 'it-IT',
  author: { '@type': 'Organization', name: SITE.author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/logo-mark.svg', SITE.url).href,
    },
  },
  keywords: tags.join(', '),
  url: pageUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  ...(ogImage ? { image: new URL(ogImage, SITE.url).href } : {}),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'News', item: new URL('/news', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout
  title={title}
  description={excerpt}
  image={ogImage}
  type="article"
  jsonLd={[jsonLd, breadcrumb]}
>
  <article class="post">
    <header class="wrap post__head">
      <div class="post__meta reveal">
        <FormattedDate date={date} />
        <span aria-hidden="true">·</span>
        <span>{readingTime} min di lettura</span>
        {tags.length > 0 && (
          <ul class="post__tags">
            {tags.map((t) => (
              <li><a href={`/news/tag/${slugify(t)}`}>#{t}</a></li>
            ))}
          </ul>
        )}
      </div>
      <h1 class="reveal reveal-lines"><span class="line"><span>{title}</span></span></h1>
      <p class="post__excerpt reveal" style="--i: 1">{excerpt}</p>
    </header>

    {
      cover && (
        <div class="wrap post__cover reveal media-reveal">
          <Picture
            src={cover}
            formats={['avif', 'webp']}
            alt={`Copertina: ${title}`}
            widths={[600, 1000, 1600]}
            sizes="(min-width: 68rem) 68rem, 100vw"
            loading="eager"
          />
        </div>
      )
    }

    <div class="wrap prose flow">
      <Content />
    </div>

    {
      (older || newer) && (
        <nav class="wrap post__nav" aria-label="Altri articoli">
          {older ? (
            <a href={`/news/${older.id}`} class="post__nav-item post__nav-item--prev">
              <span class="post__nav-label"><span aria-hidden="true">←</span> Precedente</span>
              <span class="post__nav-title">{older.title}</span>
            </a>
          ) : (
            <span />
          )}
          {newer && (
            <a href={`/news/${newer.id}`} class="post__nav-item post__nav-item--next">
              <span class="post__nav-label">Successivo <span aria-hidden="true">→</span></span>
              <span class="post__nav-title">{newer.title}</span>
            </a>
          )}
        </nav>
      )
    }

    <div class="wrap post__back">
      <a href="/news" class="link-arrow"><span aria-hidden="true">←</span> Tutte le news</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post__head {
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--space-3);
    max-width: 48rem;
  }
  .post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--step--1);
    color: var(--color-muted);
  }
  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post__tags a {
    color: var(--color-muted);
    text-decoration: none;
  }
  .post__tags a:hover {
    color: var(--color-accent);
  }
  .post__head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-2);
  }
  .post__excerpt {
    margin-top: var(--space-2);
    font-size: var(--step-1);
    color: var(--color-ink-soft);
  }
  .post__cover {
    margin-block: var(--space-3) var(--space-5);
  }
  .post__cover :global(img) {
    width: 100%;
    border-radius: var(--radius);
  }
  .post__nav {
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-2);
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-3);
  }
  @media (min-width: 40rem) {
    .post__nav {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }
  }
  .post__nav-item {
    display: grid;
    gap: 0.3rem;
    text-decoration: none;
    color: inherit;
    padding: var(--space-2);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .post__nav-item:hover {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }
  .post__nav-item--next {
    text-align: right;
  }
  .post__nav-label {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .post__nav-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--color-ink);
  }

  .post__back {
    margin-top: var(--space-4);
  }
</style>
