---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import PostCard from '../components/PostCard.astro';
import Marquee from '../components/Marquee.astro';

const works = (await getCollection('works', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero wrap">
    <p class="eyebrow reveal">Produzioni video</p>
    <h1 class="hero__title reveal reveal-lines">
      <span class="line"><span>Diamo forma alle idee,</span></span>
      <span class="line"><span>un'inquadratura alla volta.</span></span>
    </h1>
    <p class="hero__lead reveal" style="--i: 2">
      {/* Testo provvisorio — sostituibile con il testo definitivo del cliente. */}
      Centioni Produzioni racconta storie attraverso il video: dall'idea alla
      regia, fino al montaggio finale.
    </p>
    <div class="hero__actions reveal" style="--i: 3">
      <a href="#lavori" class="btn">Guarda i lavori</a>
      <a href="/chi-siamo" class="btn btn--ghost">Chi siamo</a>
    </div>
  </section>

  <!-- Running editorial band -->
  <Marquee />

  <!-- Lavori: copertine linkabili a video esterni -->
  <section id="lavori" class="wrap section section--works">
    <header class="section__head">
      <h2 class="reveal reveal-lines"><span class="line"><span>Lavori</span></span></h2>
      <p class="section__hint eyebrow reveal" style="--i: 1">Le copertine aprono il video</p>
    </header>

    {
      works.length > 0 ? (
        <div class="works-grid">
          {works.map((w, i) => (
            <WorkCard work={w} eager={i < 2} index={i % 2} />
          ))}
        </div>
      ) : (
        <p>Presto online i primi lavori.</p>
      )
    }
  </section>

  <!-- Blog -->
  {
    posts.length > 0 && (
      <section class="wrap section">
        <header class="section__head">
          <h2 class="reveal reveal-lines"><span class="line"><span>Dal blog</span></span></h2>
          <a href="/blog" class="link-arrow reveal" style="--i: 1">
            Tutti gli articoli <span aria-hidden="true">→</span>
          </a>
        </header>
        <div class="stack">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3.5rem, 10vw, 8.5rem) var(--space-5);
  }

  .hero__title {
    font-size: var(--step-4);
    margin-top: var(--space-2);
    max-width: 18ch;
  }

  .hero__lead {
    margin-top: var(--space-3);
    font-size: var(--step-1);
    color: var(--color-ink-soft);
    max-width: var(--measure);
  }

  .hero__actions {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .section {
    padding-block: var(--space-4);
  }

  .section--works {
    scroll-margin-top: 5rem;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-line);
  }

  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .section__head h2 {
    font-size: var(--step-2);
  }

  .section__hint {
    color: var(--color-muted);
  }

  .works-grid {
    display: grid;
    gap: var(--space-5) var(--space-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
  }

  .stack {
    display: grid;
    gap: var(--space-5);
  }
</style>
