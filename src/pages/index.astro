---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Slider from '../components/Slider.astro';
import Marquee from '../components/Marquee.astro';
import ProduzioneCard from '../components/ProduzioneCard.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../data/site.ts';

const produzioni = (await getCollection('produzioni', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const slides = produzioni
  .filter((p) => p.data.cover)
  .slice(0, 5)
  .map((p) => ({ src: p.data.cover!, label: p.data.title }));

const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero wrap">
    <p class="eyebrow reveal">Il canale ufficiale</p>
    <h1 class="hero__title reveal reveal-lines">
      <span class="line"><span>Centioni</span></span>
      <span class="line"><span>Produzioni</span></span>
    </h1>
    <p class="hero__lead reveal" style="--i: 2">{SITE.description}</p>
    <div class="hero__actions reveal" style="--i: 3">
      <a href="/produzioni" class="btn">Le produzioni</a>
      <a href="/contatti" class="btn btn--ghost">Contatti</a>
    </div>
  </section>

  {
    slides.length > 0 && (
      <section class="wrap hero__media reveal">
        {/* captions off: i titoli sono già nelle copertine placeholder */}
        <Slider slides={slides} captions={false} />
      </section>
    )
  }

  <Marquee />

  <!-- Produzioni -->
  <section class="wrap section">
    <header class="section__head">
      <h2 class="reveal reveal-lines"><span class="line"><span>Le Nostre Produzioni</span></span></h2>
      <a href="/produzioni" class="link-arrow reveal" style="--i: 1">
        Tutte le produzioni <span aria-hidden="true">→</span>
      </a>
    </header>
    <div class="prod-grid">
      {produzioni.map((p, i) => (
        <ProduzioneCard produzione={p} index={i % 3} eager={i < 3} />
      ))}
    </div>
  </section>

  <!-- News -->
  {
    news.length > 0 && (
      <section class="wrap section">
        <header class="section__head">
          <h2 class="reveal reveal-lines"><span class="line"><span>News &amp; Aggiornamenti</span></span></h2>
          <a href="/news" class="link-arrow reveal" style="--i: 1">
            Tutte le news <span aria-hidden="true">→</span>
          </a>
        </header>
        <div class="stack">
          {news.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Contact CTA -->
  <section class="wrap">
    <div class="cta reveal">
      <h2 class="cta__title">Hai un progetto o una collaborazione?</h2>
      <p class="cta__text">Raccontaci la tua idea: ti rispondiamo presto.</p>
      <a href="/contatti" class="btn">Scrivici</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 8vw, 6.5rem) var(--space-3);
  }
  .hero__title {
    font-size: var(--step-4);
    margin-top: var(--space-2);
    line-height: 0.98;
  }
  /* Inchiostro sfumato: dal petrol scuro al teal del brand, statico. */
  .hero__title .line > span {
    background: linear-gradient(165deg, var(--color-ink) 45%, var(--color-accent) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 0.08em; /* evita il taglio dei discendenti col clip */
  }
  .hero__lead {
    margin-top: var(--space-3);
    font-size: var(--step-1);
    color: var(--color-ink-soft);
    max-width: var(--measure);
  }
  .hero__actions {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .hero__media {
    margin-bottom: var(--space-5);
  }

  .section {
    padding-block: var(--space-4);
  }
  .section__head {
    display: flex;
    flex-wrap: wrap; /* su mobile il link scende sotto il titolo, leggibile */
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-1) var(--space-2);
    margin-bottom: var(--space-4);
  }
  .section__head h2 {
    font-size: var(--step-2);
  }

  .prod-grid {
    display: grid;
    gap: var(--space-4) var(--space-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
  }
  .stack {
    display: grid;
    gap: var(--space-5);
  }

  .cta {
    margin-block: var(--space-4) var(--space-5);
    padding: clamp(2rem, 6vw, 4rem);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    text-align: center;
  }
  .cta__title {
    font-size: var(--step-2);
  }
  .cta__text {
    margin-block: var(--space-1) var(--space-3);
    color: var(--color-ink-soft);
  }
</style>
