---
// Pannello redazione su misura. Pagina statica autonoma (niente layout del sito).
// Protetta da Cloudflare Access (login Google). Le API in /api/* committano su GitHub.
export const prerender = true;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/fraunces-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>Redazione — Centioni Produzioni</title>
    <style is:global>
      /* Font del brand, self-hosted (identici a src/styles/global.css). */
      @font-face {
        font-family: 'Fraunces'; font-style: normal; font-weight: 300 700;
        font-display: swap; src: url('/fonts/fraunces-variable.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Inter'; font-style: normal; font-weight: 100 900;
        font-display: swap; src: url('/fonts/inter-variable.woff2') format('woff2');
      }
      :root {
        /* Palette brand: petrol/teal su panna (come il sito). */
        --teal: #176b7a; --teal-deep: #0f5663; --bg: #f1eee6; --surface: #f8f6ef;
        --ink: #15323a; --soft: #43595f; --muted: #5b6661; --line: #ddd7c9;
        --ok: #2f7d5e; --err: #b23a2b; --radius: 8px;
        --font-display: 'Fraunces', Georgia, 'Times New Roman', serif;
        --font-sans: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        --shadow: 0 1px 3px rgba(20,50,58,.06), 0 8px 24px rgba(20,50,58,.06);
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--ink);
        font-family: var(--font-sans); font-size: 15px; line-height: 1.55;
        -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
      button { font: inherit; cursor: pointer; }
      /* top bar */
      .topbar { background: var(--teal); color: #fff; padding: .7rem 1.1rem;
        display: flex; align-items: center; gap: .7rem; position: sticky; top: 0; z-index: 10; }
      .topbar svg { display: block; }
      .topbar .brand { font-family: var(--font-display); font-weight: 500; font-size: 1.18rem; letter-spacing: .01em; line-height: 1; }
      .topbar .brand small { display: block; font-family: var(--font-sans); font-weight: 600; font-size: .66rem; opacity: .85; letter-spacing: .12em; text-transform: uppercase; margin-top: .18rem; }
      .topbar .spacer { margin-left: auto; }
      .topbar .who { font-size: .85rem; opacity: .95; }
      .topbar .logout { color: #fff; font-size: .8rem; text-decoration: none; border: 1px solid rgba(255,255,255,.4);
        padding: .3rem .7rem; border-radius: 100px; }
      .topbar .logout:hover { background: rgba(255,255,255,.15); }

      .wrap { max-width: 66rem; margin: 0 auto; padding: 1.2rem; }
      .tabs { display: inline-flex; background: var(--surface); border: 1px solid var(--line);
        border-radius: 100px; padding: .25rem; margin-bottom: 1.2rem; box-shadow: var(--shadow); }
      .tab { padding: .45rem 1.1rem; border: 0; background: none; border-radius: 100px;
        font-weight: 600; font-size: .9rem; color: var(--soft); }
      .tab.active { background: var(--teal); color: #fff; }

      .cols { display: grid; gap: 1.2rem; grid-template-columns: 1fr; align-items: start; }
      @media (min-width: 54rem) { .cols { grid-template-columns: 20rem 1fr; } }

      .side .newbtn { width: 100%; background: var(--teal); color: #fff; border: 0; border-radius: var(--radius);
        padding: .75rem; font-weight: 700; margin-bottom: .8rem; box-shadow: var(--shadow); }
      .side .newbtn:hover { background: var(--teal-deep); }
      .list { display: grid; gap: .5rem; }
      .card { display: grid; grid-template-columns: 3.4rem 1fr; gap: .7rem; align-items: center;
        background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
        padding: .5rem; text-align: left; width: 100%; }
      .card:hover { border-color: var(--teal); }
      .card.sel { border-color: var(--teal); box-shadow: 0 0 0 1px var(--teal) inset; }
      .card .thumb { width: 3.4rem; height: 3.4rem; border-radius: 7px; object-fit: cover; background: var(--bg);
        display: grid; place-items: center; color: var(--muted); overflow: hidden; }
      .card .thumb img { width: 100%; height: 100%; object-fit: cover; }
      .card .ttl { display: block; font-weight: 600; font-size: .9rem; line-height: 1.25; }
      .card .meta { display: block; font-size: .74rem; color: var(--muted); margin-top: .12rem; }
      .badge { display: inline-block; font-size: .64rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .05em; padding: .1em .5em; border-radius: 100px; margin-left: .3rem; }
      .badge.draft { background: #f4e3df; color: var(--err); }

      .editor { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
        padding: 1.3rem; box-shadow: var(--shadow); }
      .editor h2 { margin: 0 0 1.1rem; font-family: var(--font-display); font-weight: 500; font-size: 1.4rem; letter-spacing: -.01em; }
      .field { margin-bottom: 1rem; }
      .field > label { display: block; font-size: .76rem; font-weight: 700; color: var(--soft);
        text-transform: uppercase; letter-spacing: .04em; margin-bottom: .3rem; }
      .field input[type=text], .field input[type=date], .field input[type=number],
      .field textarea, .field select { font: inherit; padding: .6rem .7rem; border: 1px solid var(--line);
        border-radius: 8px; background: #fff; color: var(--ink); width: 100%; }
      .field input:focus, .field textarea:focus, .field select:focus { outline: 2px solid var(--teal); outline-offset: 0; border-color: var(--teal); }
      .field textarea { resize: vertical; min-height: 4.5rem; }
      .field--body textarea { min-height: 16rem; font-family: ui-monospace, 'SF Mono', monospace; font-size: .9rem; }
      .grid2 { display: grid; gap: 1rem; grid-template-columns: 1fr; }
      @media (min-width: 40rem) { .grid2 { grid-template-columns: 1fr 1fr; } }
      .check { display: flex; align-items: center; gap: .5rem; }
      .check input { width: 1.1rem; height: 1.1rem; }
      .check label { font-weight: 600; color: var(--soft); font-size: .9rem; }

      .cover { display: flex; gap: .9rem; align-items: center; flex-wrap: wrap; }
      .cover .prev { width: 8rem; height: 5rem; border-radius: 8px; background: var(--bg);
        border: 1px solid var(--line); object-fit: cover; display: grid; place-items: center; color: var(--muted); font-size: .8rem; overflow: hidden; }
      .cover .prev img { width: 100%; height: 100%; object-fit: cover; }
      .cover .filebtn { border: 1px solid var(--teal); color: var(--teal); background: #fff; border-radius: 8px; padding: .5rem .9rem; font-weight: 600; }
      .cover .rm { border: 0; background: none; color: var(--err); font-size: .82rem; text-decoration: underline; }

      .actions { display: flex; gap: .7rem; align-items: center; margin-top: 1.2rem; flex-wrap: wrap;
        border-top: 1px solid var(--line); padding-top: 1rem; }
      .btn { background: var(--teal); color: #fff; border: 0; border-radius: 8px; padding: .65rem 1.3rem; font-weight: 700; }
      .btn:hover { background: var(--teal-deep); }
      .btn[disabled] { opacity: .5; }
      .btn-del { margin-left: auto; background: none; color: var(--err); border: 1px solid var(--line); border-radius: 8px; padding: .55rem 1rem; font-weight: 600; }
      .btn-del:hover { border-color: var(--err); }
      .status { font-size: .88rem; min-height: 1.2em; }
      .status.ok, .status.err { display: inline-flex; align-items: center; gap: .4rem;
        padding: .38rem .7rem; border-radius: 7px; font-weight: 600; }
      .status.ok { color: var(--ok); background: color-mix(in srgb, var(--ok) 13%, transparent); }
      .status.err { color: var(--err); background: color-mix(in srgb, var(--err) 13%, transparent); }
      .empty { color: var(--muted); font-size: .9rem; padding: .5rem 0; }
      .gate { max-width: 34rem; margin: 4rem auto; text-align: center; padding: 1.5rem;
        background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); }
      .gate h2 { margin-top: 0; font-family: var(--font-display); font-weight: 500; font-size: 1.5rem; }
    </style>
  </head>
  <body>
    <div class="topbar">
      <svg width="30" height="30" viewBox="0 0 120 120" aria-hidden="true">
        <circle cx="55" cy="63" r="35" fill="none" stroke="#fff" stroke-width="15" stroke-linecap="round" stroke-dasharray="158 62" transform="rotate(-52 55 63)"></circle>
        <line x1="50" y1="68" x2="78" y2="40" stroke="#fff" stroke-width="15" stroke-linecap="round"></line>
        <path d="M95 23 L90 54 L63 27 Z" fill="#fff" stroke="#fff" stroke-width="4" stroke-linejoin="round"></path>
      </svg>
      <span class="brand">Redazione<small>Centioni Produzioni</small></span>
      <span class="spacer"></span>
      <span class="who" id="who"></span>
      <a class="logout" href="/cdn-cgi/access/logout">Esci</a>
    </div>

    <div class="wrap" id="app" hidden>
      <div class="tabs">
        <button class="tab active" data-type="news">📝 Articoli</button>
        <button class="tab" data-type="produzioni">🎬 Produzioni</button>
      </div>
      <div class="cols">
        <div class="side">
          <button class="newbtn" id="newBtn">+ Nuovo</button>
          <div class="list" id="list"><p class="empty">Caricamento…</p></div>
        </div>
        <div class="editor" id="editor">
          <p class="empty">Seleziona un elemento a sinistra oppure crea “Nuovo”.</p>
        </div>
      </div>
    </div>

    <div class="gate" id="gate"><p>Verifica accesso…</p></div>

    <script type="module" is:inline>
      const SCHEMAS = {
        news: {
          label: 'Articolo',
          fields: [
            { name: 'title', label: 'Titolo', type: 'text', required: true },
            { name: 'date', label: 'Data', type: 'date', required: true, half: true },
            { name: 'draft', label: 'Salva come bozza (non pubblicato)', type: 'checkbox', half: true },
            { name: 'cover', label: 'Copertina', type: 'image' },
            { name: 'excerpt', label: 'Estratto (riassunto breve)', type: 'textarea', required: true },
            { name: 'tags', label: 'Tag (separati da virgola)', type: 'text' },
            { name: 'body', label: 'Contenuto (Markdown)', type: 'body' },
          ],
        },
        produzioni: {
          label: 'Produzione',
          fields: [
            { name: 'title', label: 'Titolo', type: 'text', required: true },
            { name: 'status', label: 'Stato', type: 'select', required: true, half: true,
              options: [['in-corso', 'In corso'], ['in-uscita', 'In uscita']] },
            { name: 'order', label: 'Ordine (più basso = prima)', type: 'number', half: true },
            { name: 'cover', label: 'Copertina', type: 'image' },
            { name: 'youtube', label: 'ID video o playlist YouTube', type: 'text', half: true,
              hint: 'Da watch?v=ABC123 → ABC123 · da playlist?list=PLxyz → PLxyz' },
            { name: 'video', label: 'Link video esterno (https://…)', type: 'text', half: true },
            { name: 'releaseLabel', label: 'Etichetta di uscita (es. “In uscita · Agosto 2026”)', type: 'text' },
            { name: 'description', label: 'Descrizione', type: 'textarea' },
            { name: 'draft', label: 'Salva come bozza (non pubblicato)', type: 'checkbox' },
          ],
        },
      };

      let currentType = 'news';
      let currentSlug = '';
      const $ = (s) => document.querySelector(s);
      const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      // Se la pagina è servita con un token di sessione (SESSION_SECRET
      // configurato), parliamo con /cms/* passando il token negli header:
      // nessuna dipendenza dal cookie di Access. Altrimenti /api/* (via Access).
      const TOKEN = document.querySelector('meta[name="cms-token"]')?.content || '';
      const BASE = TOKEN ? '/cms' : '/api';
      async function api(path, opts = {}) {
        const headers = { ...(opts.headers || {}) };
        if (TOKEN) headers.Authorization = 'Bearer ' + TOKEN;
        const r = await fetch(BASE + path, { ...opts, headers });
        const d = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(d.error || `Errore ${r.status}`);
        return d;
      }

      async function init() {
        try {
          const me = await api('/me');
          $('#who').textContent = me.email;
          $('#gate').hidden = true;
          $('#app').hidden = false;
          document.querySelectorAll('.tab').forEach((t) =>
            t.addEventListener('click', () => {
              document.querySelectorAll('.tab').forEach((x) => x.classList.remove('active'));
              t.classList.add('active');
              currentType = t.dataset.type;
              clearEditor();
              loadList();
            }));
          $('#newBtn').addEventListener('click', () => renderForm(null));
          loadList();
        } catch (e) {
          $('#gate').innerHTML = '<h2>Accesso non riuscito</h2><p>' + esc(e.message) +
            '</p><p style="color:#7c857f;font-size:.9rem">Se hai già fatto il login, ricarica la pagina. Se il problema persiste, verifica le variabili su Cloudflare Pages (<b>SESSION_SECRET</b> per /cms, oppure <b>CF_ACCESS_AUD</b> per /api) e che l\'app Access protegga <b>/admin</b>.</p>';
        }
      }

      function clearEditor() {
        currentSlug = '';
        $('#editor').innerHTML = '<p class="empty">Seleziona un elemento a sinistra oppure crea “Nuovo”.</p>';
      }

      async function loadList() {
        const list = $('#list');
        list.innerHTML = '<p class="empty">Caricamento…</p>';
        try {
          const { items } = await api('/list?type=' + currentType);
          if (!items.length) { list.innerHTML = '<p class="empty">Nessun elemento. Crea il primo con “+ Nuovo”.</p>'; return; }
          list.innerHTML = '';
          for (const it of items) {
            const b = document.createElement('button');
            b.className = 'card' + (it.slug === currentSlug ? ' sel' : '');
            const meta = currentType === 'news' ? (it.date || '') : (it.status === 'in-corso' ? 'In corso' : (it.releaseLabel || 'In uscita'));
            const thumb = it.coverUrl
              ? `<img src="${esc(it.coverUrl)}" alt="" loading="lazy" onerror="this.style.display='none'">`
              : '🎬';
            b.innerHTML = `<span class="thumb">${thumb}</span><span>` +
              `<span class="ttl">${esc(it.title || it.slug)}</span>` +
              `<span class="meta">${esc(meta)}${it.draft ? '<span class="badge draft">bozza</span>' : ''}</span></span>`;
            b.addEventListener('click', () => openEntry(it.slug));
            list.appendChild(b);
          }
        } catch (e) { list.innerHTML = '<p class="status err">' + esc(e.message) + '</p>'; }
      }

      async function openEntry(slug) {
        try {
          const res = await api(`/entry?type=${currentType}&slug=${encodeURIComponent(slug)}`);
          renderForm({ slug, ...res });
        } catch (e) { alert(e.message); }
      }

      function renderForm(entry) {
        const schema = SCHEMAS[currentType];
        const data = entry?.data || {};
        currentSlug = entry?.slug || '';
        let rows = '';
        let pending = [];
        for (const f of schema.fields) {
          const val = f.name === 'body' ? (entry?.body || '') : data[f.name];
          const html = renderField(f, val, entry?.coverUrl);
          if (f.half) { pending.push(html); if (pending.length === 2) { rows += `<div class="grid2">${pending.join('')}</div>`; pending = []; } }
          else { if (pending.length) { rows += `<div class="grid2">${pending.join('')}</div>`; pending = []; } rows += html; }
        }
        if (pending.length) rows += `<div class="grid2">${pending.join('')}</div>`;

        $('#editor').innerHTML =
          `<h2>${entry ? 'Modifica' : 'Nuovo'} · ${schema.label}</h2>` +
          `<form id="form">${rows}<div class="actions">` +
          `<button type="submit" class="btn">Salva e pubblica</button>` +
          `<span class="status" id="formStatus"></span>` +
          (entry ? `<button type="button" class="btn-del" id="delBtn">Elimina</button>` : '') +
          `</div></form>`;
        const form = $('#form');
        form.querySelectorAll('input[type=file]').forEach(bindUpload);
        form.querySelectorAll('.rm').forEach((btn) => btn.addEventListener('click', () => clearCover(btn.dataset.for)));
        form.onsubmit = onSave;
        if (entry) $('#delBtn').addEventListener('click', () => onDelete(entry.slug));
        document.querySelectorAll('.card').forEach((c) => c.classList.remove('sel'));
      }

      function renderField(f, val, coverUrl) {
        const id = 'f_' + f.name;
        const hint = f.hint ? `<div style="font-size:.75rem;color:var(--muted);margin-top:.2rem">${esc(f.hint)}</div>` : '';
        let inner;
        if (f.type === 'textarea' || f.type === 'body')
          inner = `<textarea id="${id}" name="${f.name}">${esc(val)}</textarea>`;
        else if (f.type === 'checkbox')
          return `<div class="field"><div class="check"><input type="checkbox" id="${id}" name="${f.name}" ${val ? 'checked' : ''}><label for="${id}">${esc(f.label)}</label></div></div>`;
        else if (f.type === 'select')
          inner = `<select id="${id}" name="${f.name}">` +
            f.options.map(([v, l]) => `<option value="${v}" ${val === v ? 'selected' : ''}>${esc(l)}</option>`).join('') + '</select>';
        else if (f.type === 'image') {
          const prev = val ? `<img src="${esc(coverUrl || '')}" alt="">` : 'Nessuna';
          return `<div class="field"><label>${esc(f.label)}</label><div class="cover">` +
            `<span class="prev" id="${id}_prev">${prev}</span>` +
            `<div><input type="hidden" id="${id}" name="${f.name}" value="${esc(val || '')}">` +
            `<label class="filebtn">Carica immagine<input type="file" accept=".jpg,.jpeg,.png,.webp,.avif,image/jpeg,image/png,image/webp,image/avif" data-target="${id}" hidden></label>` +
            (val ? ` <button type="button" class="rm" data-for="${id}">rimuovi</button>` : '') +
            `</div></div></div>`;
        } else if (f.type === 'date')
          inner = `<input type="date" id="${id}" name="${f.name}" value="${esc(val ?? '')}" ${f.required ? 'required' : ''}>`;
        else if (f.type === 'number')
          inner = `<input type="number" id="${id}" name="${f.name}" value="${esc(val ?? '')}">`;
        else
          inner = `<input type="text" id="${id}" name="${f.name}" value="${esc(val ?? '')}" ${f.required ? 'required' : ''}>`;
        const cls = f.type === 'body' ? 'field field--body' : 'field';
        return `<div class="${cls}"><label for="${id}">${esc(f.label)}${f.required ? ' *' : ''}</label>${inner}${hint}</div>`;
      }

      function clearCover(id) {
        document.getElementById(id).value = '';
        document.getElementById(id + '_prev').textContent = 'Nessuna';
        const rm = document.querySelector(`.rm[data-for="${id}"]`);
        if (rm) rm.remove();
      }

      function bindUpload(input) {
        input.addEventListener('change', async () => {
          const file = input.files[0];
          if (!file) return;
          const status = $('#formStatus');
          status.textContent = 'Ottimizzo immagine…'; status.className = 'status';
          try {
            const prepared = await prepareImage(file);
            status.textContent = 'Carico immagine…';
            const dataBase64 = await fileToBase64(prepared);
            const res = await api('/upload', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ filename: prepared.name, dataBase64 }),
            });
            const target = document.getElementById(input.dataset.target);
            target.value = res.path;
            document.getElementById(input.dataset.target + '_prev').innerHTML =
              `<img src="${URL.createObjectURL(prepared)}" alt="">`;
            status.textContent = `Immagine caricata ✓ (${Math.max(1, Math.round(prepared.size / 1024))} KB)`;
            status.className = 'status ok';
          } catch (e) { status.textContent = e.message; status.className = 'status err'; }
        });
      }

      // Compressione automatica delle copertine prima dell'upload: le foto da
      // telefono (3–8 MB) diventano ~200–400 KB, così repo e build restano leggeri.
      const IMG_MAX_SIDE = 1920;      // lato massimo: oltre non serve al layout
      const IMG_SKIP_BYTES = 500 * 1024;   // già leggera → invio l'originale
      const IMG_MAX_BYTES = 8 * 1024 * 1024; // stesso tetto del server

      async function prepareImage(file) {
        const okExt = /\.(jpe?g|png|webp|avif)$/i.test(file.name);
        if (okExt && file.size <= IMG_SKIP_BYTES) return file;
        try {
          let bmp;
          try {
            bmp = await createImageBitmap(file, { imageOrientation: 'from-image' });
          } catch {
            bmp = await createImageBitmap(file); // browser senza opzioni
          }
          const scale = Math.min(1, IMG_MAX_SIDE / Math.max(bmp.width, bmp.height));
          const canvas = document.createElement('canvas');
          canvas.width = Math.max(1, Math.round(bmp.width * scale));
          canvas.height = Math.max(1, Math.round(bmp.height * scale));
          canvas.getContext('2d').drawImage(bmp, 0, 0, canvas.width, canvas.height);
          bmp.close();
          let blob = await new Promise((res) => canvas.toBlob(res, 'image/webp', 0.82));
          if (!blob || blob.type !== 'image/webp') {
            blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', 0.85));
          }
          if (!blob) throw new Error('encode');
          // se la ricompressione non guadagna nulla, tengo l'originale
          if (okExt && blob.size >= file.size && file.size <= IMG_MAX_BYTES) return file;
          const ext = blob.type === 'image/webp' ? 'webp' : 'jpg';
          const base = (file.name.replace(/\.[^.]+$/, '') || 'immagine');
          return new File([blob], `${base}.${ext}`, { type: blob.type });
        } catch {
          if (okExt && file.size <= IMG_MAX_BYTES) return file; // fallback: originale
          throw new Error('Immagine non leggibile o troppo grande: usa JPG, PNG, WebP o AVIF fino a 8 MB.');
        }
      }

      function fileToBase64(file) {
        return new Promise((resolve, reject) => {
          const r = new FileReader();
          r.onload = () => resolve(String(r.result).split(',')[1]);
          r.onerror = reject;
          r.readAsDataURL(file);
        });
      }

      async function onSave(e) {
        e.preventDefault();
        const form = e.target;
        const schema = SCHEMAS[currentType];
        const status = $('#formStatus');
        const data = {}; let body = '';
        for (const f of schema.fields) {
          const el = form.querySelector(`[name="${f.name}"]`);
          if (!el) continue;
          if (f.name === 'body') { body = el.value; continue; }
          if (f.type === 'checkbox') data[f.name] = el.checked;
          else if (el.value !== '') data[f.name] = el.value;
        }
        status.textContent = 'Salvataggio…'; status.className = 'status';
        const btn = form.querySelector('button[type=submit]'); btn.disabled = true;
        try {
          const res = await api('/save', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: currentType, slug: currentSlug || undefined, data, body }),
          });
          currentSlug = res.slug;
          status.textContent = 'Salvato ✓ Il sito si aggiorna tra 1–2 minuti.'; status.className = 'status ok';
          loadList();
        } catch (e2) { status.textContent = e2.message; status.className = 'status err'; }
        finally { btn.disabled = false; }
      }

      async function onDelete(slug) {
        if (!confirm('Eliminare definitivamente questo elemento?')) return;
        const status = $('#formStatus');
        status.textContent = 'Elimino…'; status.className = 'status';
        try {
          await api('/delete', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: currentType, slug }),
          });
          clearEditor(); loadList();
        } catch (e) { status.textContent = e.message; status.className = 'status err'; }
      }

      init();
    </script>
  </body>
</html>
