---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.ts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About',
  url: new URL('/about', SITE.url).href,
  about: { '@type': 'Organization', name: SITE.name },
};
---

<BaseLayout
  title="About"
  description="Chi sono e come lavoro. Contatti e collaborazioni."
  jsonLd={jsonLd}
>
  <section class="wrap page-head">
    <p class="eyebrow reveal">About</p>
    <h1 class="reveal">Chi c'è dietro</h1>
  </section>

  <section class="wrap about flow">
    <p class="about__lead reveal">
      Sono {SITE.name}. Mi occupo di produzioni e progetti, dall'idea alla
      consegna. Questo spazio raccoglie i lavori e i racconti dietro le quinte.
    </p>
    <p class="reveal">
      Questo testo è un segnaposto: lo sostituiremo con la biografia reale e il
      tono di voce definitivo una volta impostato il design su misura.
    </p>

    <div class="about__contact reveal">
      <h2>Contatti</h2>
      <p>
        Per collaborazioni e richieste:
        <a href="mailto:hello@centioniproduzioni.it">hello@centioniproduzioni.it</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--space-3);
  }
  .page-head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-1);
  }
  .about {
    max-width: var(--measure);
    padding-bottom: var(--space-4);
  }
  .about__lead {
    font-size: var(--step-1);
    color: var(--color-ink-soft);
  }
  .about__contact {
    margin-top: var(--space-4);
  }
  .about__contact h2 {
    font-size: var(--step-1);
    margin-bottom: var(--space-1);
  }
</style>
