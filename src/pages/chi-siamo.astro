---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIAL } from '../data/site.ts';
import fondatori from '../assets/media/fondatori.jpg';

const sameAs = SOCIAL.filter((s) => /^https?:\/\//.test(s.href)).map((s) => s.href);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Chi Siamo',
  url: new URL('/chi-siamo', SITE.url).href,
  about: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    image: new URL(fondatori.src, SITE.url).href,
    founder: [
      { '@type': 'Person', name: 'Gaetano Campolo' },
      { '@type': 'Person', name: 'Niccolò Centioni', ...(sameAs.length ? { sameAs } : {}) },
    ],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Chi Siamo' },
  ],
};
---

<BaseLayout
  title="Chi Siamo"
  description="Centioni Produzioni nasce dalla sinergia tra l'esperienza digitale di Gaetano Campolo e l'estro artistico di Niccolò Centioni: format innovativi per intrattenere, comunicare e valorizzare il territorio."
  image="/og/chi-siamo.jpg"
  jsonLd={[jsonLd, breadcrumb]}
>
  <section class="wrap page-head">
    <p class="eyebrow reveal">Chi Siamo</p>
    <h1 class="reveal reveal-lines">
      <span class="line"><span>Centioni Produzioni</span></span>
    </h1>
  </section>

  <section class="wrap about">
    <figure class="about__portrait reveal media-reveal">
      <Picture
        src={fondatori}
        formats={['avif', 'webp']}
        alt="Gaetano Campolo e Niccolò Centioni, fondatori di Centioni Produzioni"
        widths={[480, 800, 1000]}
        sizes="(min-width: 52rem) 40vw, 100vw"
        loading="eager"
      />
    </figure>

    <div class="about__content">
      <div class="about__body flow">
        <p class="about__lead reveal">
          Centioni Produzioni nasce dalla sinergia strategica tra l'esperienza
          digitale di <strong>Gaetano Campolo</strong> e l'estro artistico di
          <strong>Niccolò Centioni</strong>, che firma l'azienda e i contenuti
          a suo nome.
        </p>
        <p class="reveal">
          Insieme a un team affiatato di video maker, influencer e personaggi
          del mondo dello spettacolo in veste di collaboratori e inviati,
          diamo vita a format innovativi, capaci di intrattenere, comunicare e
          valorizzare il territorio.
        </p>
      </div>

      <div class="about__card reveal">
        <p class="about__cardlabel">In breve</p>
        <ul class="about__facts">
          <li><span>Brand</span>{SITE.name}</li>
          <li><span>Fondatori</span>Gaetano Campolo · Niccolò Centioni</li>
          <li><span>Ambiti</span>Video · Format · Social · News</li>
        </ul>
        <a href="/contatti" class="btn">Lavoriamo insieme</a>
      </div>
    </div>
  </section>

  <section class="wrap story">
    <h2 class="story__title reveal reveal-lines">
      <span class="line"><span>La nostra storia: l'incontro tra</span></span>
      <span class="line"><span>visione digitale e talento artistico</span></span>
    </h2>

    <div class="founders">
      <article class="founder reveal">
        <h3>Gaetano Campolo</h3>
        <p class="founder__role">L'anima digitale e l'imprenditoria d'avanguardia</p>
        <div class="flow">
          <p>
            Pioniere del digitale e imprenditore poliedrico originario di
            Reggio Calabria, Gaetano Campolo ha ridefinito le regole del
            mercato digitale in Italia grazie alla sua spiccata attitudine
            all'innovazione. Già fondatore e CEO di piattaforme di successo
            nazionale come <em>Home Restaurant Hotel</em> — un progetto
            rivoluzionario che ha unito sharing economy e valorizzazione delle
            eccellenze italiane — Gaetano ha saputo trasformare le nuove
            tecnologie in concrete opportunità di business e comunicazione.
          </p>
          <p>
            All'interno di Centioni Produzioni, Campolo mette in campo la sua
            profonda competenza strategica, la gestione manageriale e la
            visione lungimirante nel marketing digitale, strutturando
            l'azienda come una realtà solida e proiettata verso il futuro dei
            media.
          </p>
        </div>
      </article>

      <article class="founder reveal" style="--i: 1">
        <h3>Niccolò Centioni</h3>
        <p class="founder__role">Il volto e la firma creativa</p>
        <div class="flow">
          <p>
            Attore tra i più amati dal pubblico italiano e volto storico della
            televisione, Niccolò Centioni ha conquistato il cuore di milioni
            di spettatori interpretando per anni il personaggio di Rudi nella
            celebre fiction <em>I Cesaroni</em>. Con una carriera cresciuta
            sotto i riflettori e una profonda conoscenza dei meccanismi dello
            spettacolo, del cinema e della televisione, Niccolò porta nel
            progetto la firma artistica, la credibilità del suo nome e la sua
            naturale capacità di comunicare ed emozionare il pubblico.
          </p>
          <p>
            In veste di direttore creativo e ideatore dei contenuti, Niccolò
            firma i format dell'azienda (come il progetto
            <em>Centioni's Kitchen</em>), guidando il team creativo con
            l'obiettivo di realizzare prodotti video che uniscano la qualità
            del linguaggio televisivo alla freschezza e all'immediatezza del
            web.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="wrap team">
    <h2 class="story__title reveal reveal-lines">
      <span class="line"><span>Una squadra in continua evoluzione</span></span>
    </h2>
    <div class="team__body flow">
      <p class="reveal">
        Ciò che rende unica Centioni Produzioni è la capacità di aggregare
        talenti. Non siamo solo un'agenzia di produzione, ma un vero e proprio
        hub creativo: grazie alla forte rete di relazioni costruita dai
        fondatori, l'azienda si avvale del supporto di video maker
        professionisti, influencer di rilievo e VIP del panorama nazionale,
        che collaborano attivamente come inviati, volti e co-autori dei vari
        format in corso.
      </p>
      <p class="team__closing reveal">
        Dall'unione tra la solidità digitale di Gaetano Campolo e l'estro
        espressivo di Niccolò Centioni, Centioni Produzioni si propone oggi
        come il partner ideale per creare contenuti multimediali capaci di
        lasciare il segno.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 7vw, 5.5rem) var(--space-3);
  }
  .page-head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-1);
  }

  .about {
    display: grid;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
  }
  @media (min-width: 52rem) {
    .about {
      grid-template-columns: 2fr 3fr;
      gap: var(--space-6);
      align-items: stretch;
    }
  }

  .about__portrait {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-line);
    aspect-ratio: 4 / 5;
  }
  .about__portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Desktop: la foto riempie l'intera altezza della colonna di testo —
     niente vuoto sotto, composizione a due colonne piena. */
  @media (min-width: 52rem) {
    .about__portrait {
      aspect-ratio: auto;
      height: 100%;
    }
  }

  .about__body {
    max-width: var(--measure);
  }
  .about__lead {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.2;
    color: var(--color-ink);
  }
  .about__body p:not(.about__lead) {
    color: var(--color-ink-soft);
  }

  .about__card {
    margin-top: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-3);
    max-width: var(--measure);
  }
  .about__cardlabel {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-accent);
  }
  .about__facts {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-3);
    display: grid;
    gap: 0.6rem;
  }
  .about__facts li {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.5rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-line);
    font-size: var(--step-0);
  }
  .about__facts span {
    color: var(--color-muted);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    align-self: center;
  }

  /* --- La nostra storia: le due bio dei fondatori --- */
  .story {
    padding-bottom: var(--space-5);
  }
  .story__title {
    font-size: var(--step-2);
    margin-bottom: var(--space-4);
    max-width: 46rem;
  }
  .founders {
    display: grid;
    gap: var(--space-4);
  }
  @media (min-width: 52rem) {
    .founders {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }
  .founder {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  .founder h3 {
    font-size: var(--step-1);
  }
  .founder__role {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0.35rem 0 var(--space-2);
  }
  .founder p:not(.founder__role) {
    color: var(--color-ink-soft);
  }

  .team {
    padding-bottom: var(--space-6);
  }
  .team__body {
    max-width: var(--measure);
  }
  .team__body p {
    color: var(--color-ink-soft);
  }
  .team__closing {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.35;
    color: var(--color-ink);
  }
</style>
