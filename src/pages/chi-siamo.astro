---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.ts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Chi Siamo',
  url: new URL('/chi-siamo', SITE.url).href,
  about: {
    '@type': 'Person',
    name: SITE.person,
    worksFor: { '@type': 'Organization', name: SITE.name },
  },
};
---

<BaseLayout
  title="Chi Siamo"
  description="La storia di Niccolò Centioni e la nascita di Centioni Produzioni."
  jsonLd={jsonLd}
>
  <section class="wrap page-head">
    <p class="eyebrow reveal">Chi Siamo</p>
    <h1 class="reveal reveal-lines">
      <span class="line"><span>La storia di</span></span>
      <span class="line"><span>Niccolò Centioni</span></span>
    </h1>
  </section>

  <section class="wrap about">
    <div class="about__body flow">
      <p class="about__lead reveal">
        Dalle prime esperienze nel mondo dello spettacolo fino ai successi
        televisivi che lo hanno reso un volto amato dal pubblico.
      </p>
      <p class="reveal">
        Questa sezione racconta il percorso artistico e professionale di Niccolò
        Centioni: la sua evoluzione, umana e lavorativa, attraverso gli anni
        passati davanti e dietro la macchina da presa.
      </p>
      <p class="reveal">
        Un cammino che arriva fino a oggi, con la nascita di
        <strong>Centioni Produzioni</strong>: la nuova realtà con cui Niccolò
        firma e realizza i suoi contenuti video, i suoi format per i social e i
        suoi nuovi progetti digitali.
      </p>
      <p class="reveal">
        È da qui che prendono vita i progetti — da <em>Centioni's Kitchen</em>
        ai nuovi format in arrivo: un unico spazio dove ideare, produrre e
        raccontare.
      </p>
    </div>

    <aside class="about__aside reveal">
      <div class="about__card">
        <p class="about__cardlabel">In breve</p>
        <ul class="about__facts">
          <li><span>Brand</span>{SITE.name}</li>
          <li><span>Volto</span>{SITE.person}</li>
          <li><span>Ambiti</span>Video · Social · Blog · News</li>
        </ul>
        <a href="/contatti" class="btn">Lavoriamo insieme</a>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 7vw, 5.5rem) var(--space-3);
  }
  .page-head h1 {
    font-size: var(--step-3);
    margin-top: var(--space-1);
  }
  .about {
    display: grid;
    gap: var(--space-5);
    padding-bottom: var(--space-5);
  }
  @media (min-width: 52rem) {
    .about {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-6);
    }
  }
  .about__body {
    max-width: var(--measure);
  }
  .about__lead {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.2;
    color: var(--color-ink);
  }
  .about__body p:not(.about__lead) {
    color: var(--color-ink-soft);
  }
  .about__card {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-3);
  }
  .about__cardlabel {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-accent);
  }
  .about__facts {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-3);
    display: grid;
    gap: 0.6rem;
  }
  .about__facts li {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.5rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-line);
    font-size: var(--step-0);
  }
  .about__facts span {
    color: var(--color-muted);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    align-self: center;
  }
</style>
